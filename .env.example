# Copy this file to ".env" for local development (Supabase sync).
# These are PUBLIC client keys — the anon key is safe to expose in a browser app.
# Leave blank to run in local-only mode (no cloud sync).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic API key — required for AI similar-problem generation in 오답노트.
# Get one at https://console.anthropic.com/
# Warning: this key will be visible in browser JS bundles. Use a low-budget key for personal use.
VITE_ANTHROPIC_API_KEY=
